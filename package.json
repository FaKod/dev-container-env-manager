{
  "name": "devenv-manager",
  "version": "0.0.40",
  "description": "Agentic Dev Environment Manager",
  "author": "FaKods",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev -- --no-sandbox",
    "build": "electron-vite build",
    "start": "electron-vite dev -- --no-sandbox",
    "preview": "electron . --no-sandbox",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "dist": "node scripts/bump-version.js && npm run dist:build",
    "dist:build": "electron-vite build && CC=x86_64-linux-gnu-gcc CXX=x86_64-linux-gnu-g++ LINK=x86_64-linux-gnu-g++ electron-builder --linux AppImage --x64",
    "dist:mac": "electron-vite build && electron-builder --mac dmg",
    "rebuild": "electron-rebuild -f -w node-pty",
    "postinstall": "electron-rebuild -f -w node-pty"
  },
  "build": {
    "appId": "com.devenv.manager",
    "productName": "FaKods Legendary DevContainer Manager",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "extraMetadata": {
      "main": "out/main/index.js"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools"
    },
    "nativeRebuilder": "legacy"
  },
  "dependencies": {
    "electron-store": "^11.0.2",
    "lucide-react": "^1.8.0",
    "node-pty": "^1.0.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^6.0.0-beta.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "zustand": "^5.0.12"
  }
}
